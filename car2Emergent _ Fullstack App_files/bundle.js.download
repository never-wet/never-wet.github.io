,400&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@300;400;500&display=swap');\n\n@tailwind base;\n@tailwind components;\n@tailwind utilities;\n\n:root {\n    --ink: #0e0e10;\n    --ink-2: #17171a;\n    --ink-3: #222226;\n    --bone: #f2f2f2;\n    --bone-2: #d8d8d4;\n    --mute: #6b6b72;\n    --rule: rgba(242, 242, 242, 0.08);\n    --accent: #c9a25a;\n    --accent-soft: rgba(201, 162, 90, 0.18);\n    --display: 'Fraunces', 'Times New Roman', serif;\n    --sans: 'Geist', system-ui, sans-serif;\n    --mono: 'Geist Mono', ui-monospace, monospace;\n}\n\n* {\n    box-sizing: border-box;\n}\n\nhtml, body {\n    margin: 0;\n    padding: 0;\n    background: var(--ink);\n    color: var(--bone);\n    font-family: var(--sans);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    overscroll-behavior: none;\n}\n\nbody {\n    overflow-x: hidden;\n}\n\n::selection {\n    background: var(--accent);\n    color: var(--ink);\n}\n\n/* Custom scrollbar — minimal */\n::-webkit-scrollbar {\n    width: 0px;\n    background: transparent;\n}\n\n/* Helpers */\n.font-display { font-family: var(--display); font-feature-settings: \"ss01\", \"ss02\"; }\n.font-sans { font-family: var(--sans); }\n.font-mono { font-family: var(--mono); }\n\n.tag {\n    font-family: var(--mono);\n    font-size: 10px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--bone-2);\n}\n\n.rule {\n    height: 1px;\n    background: var(--rule);\n    width: 100%;\n}\n\n.hero-title {\n    font-family: var(--display);\n    font-weight: 300;\n    letter-spacing: -0.04em;\n    line-height: 0.92;\n}\n\n.hero-title em {\n    font-style: italic;\n    color: var(--accent);\n}\n\n/* Gradient overlays for cinematic depth */\n.vignette {\n    background: radial-gradient(120% 80% at 50% 50%, transparent 40%, rgba(0,0,0,0.6) 100%);\n    pointer-events: none;\n}\n\n.grain {\n    background-image: url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.95  0 0 0 0 0.95  0 0 0 0 0.95  0 0 0 0.06 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>\");\n    mix-blend-mode: overlay;\n    pointer-events: none;\n}\n\n/* Custom cursor dot */\n.cursor-dot {\n    position: fixed;\n    top: 0; left: 0;\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--accent);\n    pointer-events: none;\n    z-index: 9999;\n    transform: translate(-50%, -50%);\n    transition: transform 0.18s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.2s;\n    mix-blend-mode: difference;\n}\n.cursor-ring {\n    position: fixed;\n    top: 0; left: 0;\n    width: 36px; height: 36px;\n    border-radius: 50%;\n    border: 1px solid rgba(242, 242, 242, 0.35);\n    pointer-events: none;\n    z-index: 9998;\n    transform: translate(-50%, -50%);\n    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.2s, opacity 0.2s;\n}\n\n/* Loader */\n.loader-bar {\n    height: 1px;\n    background: var(--bone);\n    transform-origin: left center;\n}\n\n/* Stage section spacer (controls scroll length) */\n.stage-spacer {\n    height: 100vh;\n}\n\n/* Buttons */\n.btn-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.6rem 1.1rem;\n    border: 1px solid rgba(242, 242, 242, 0.2);\n    border-radius: 999px;\n    font-family: var(--mono);\n    font-size: 11px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--bone);\n    background: rgba(14, 14, 16, 0.4);\n    backdrop-filter: blur(12px);\n    transition: border-color 0.25s, color 0.25s, background 0.25s, transform 0.25s;\n    cursor: pointer;\n}\n.btn-pill:hover {\n    border-color: var(--accent);\n    color: var(--accent);\n    transform: translateY(-1px);\n}\n\n/* Car selector chip */\n.car-chip {\n    font-family: var(--mono);\n    font-size: 11px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--mute);\n    padding: 0.4rem 0;\n    border: none;\n    background: transparent;\n    cursor: pointer;\n    transition: color 0.25s;\n    text-align: left;\n    white-space: nowrap;\n}\n.car-chip:hover { color: var(--bone-2); }\n.car-chip.active { color: var(--bone); }\n.car-chip.active::before {\n    content: '';\n    display: inline-block;\n    width: 18px;\n    height: 1px;\n    background: var(--accent);\n    vertical-align: middle;\n    margin-right: 10px;\n    transition: width 0.3s;\n}\n.car-chip:not(.active)::before {\n    content: '';\n    display: inline-block;\n    width: 8px;\n    height: 1px;\n    background: var(--rule);\n    vertical-align: middle;\n    margin-right: 10px;\n}\n\n/* Stage indicator */\n.stage-pill {\n    font-family: var(--mono);\n    font-size: 10px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    padding: 0.3rem 0.7rem;\n    border: 1px solid var(--rule);\n    border-radius: 999px;\n    color: var(--bone-2);\n    transition: all 0.4s;\n}\n.stage-pill.active {\n    color: var(--ink);\n    background: var(--bone);\n    border-color: var(--bone);\n}\n\n/* Reveal animation */\n@keyframes rise {\n    from { opacity: 0; transform: translateY(20px); }\n    to { opacity: 1; transform: translateY(0); }\n}\n.rise { animation: rise 1.1s cubic-bezier(0.2, 0.8, 0.2, 1) both; }\n\n@keyframes fade {\n    from { opacity: 0; }\n    to { opacity: 1; }\n}\n.fade { animation: fade 1.4s ease both; }\n\n/* Feature label connector */\n.feature-line {\n    position: absolute;\n    height: 1px;\n    background: linear-gradient(to right, var(--accent), transparent);\n    transform-origin: left;\n}\n.feature-dot {\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 12px var(--accent-soft);\n}\n\n/* Hide cursor when device is touch */\n@media (hover: none) {\n    .cursor-dot, .cursor-ring { display: none; }\n}\n\n/* Reduce motion */\n@media (prefers-reduced-motion: reduce) {\n    * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }\n}\n\n/* Layout for full-bleed canvas */\n.canvas-fixed {\n    position: fixed;\n    inset: 0;\n    z-index: 1;\n}\n.scroll-content {\n    position: relative;\n    z-index: 2;\n    pointer-events: none;\n}\n.scroll-content > * { pointer-events: auto; }\n"],"sourceRoot":""}]);
